# ============================================================
# iCross Agent — Environment Configuration
# Copy this file to .env and fill in your API keys
# ============================================================

# ── LLM Provider API Keys ──
# At least ONE provider is required. DeepSeek or MiniMax recommended.

# DeepSeek (OpenAI-compatible, used as fast/default tier)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# MiniMax (Anthropic-compatible, used as main agent LLM)
# MINIMAX_API_KEY=sk-your-minimax-api-key

# Anthropic Claude (optional backup)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# OpenAI (optional)
# OPENAI_API_KEY=sk-your-openai-api-key

# ── Ozon Marketplace API ──
# Required for Ozon shop operations
OZON_CLIENT_ID=your-ozon-client-id
OZON_API_KEY=your-ozon-api-key

# ── Image Generation (optional) ──
# VolcEngine / Seedream for AI image generation
# VOLC_ACCESS_KEY=your-volc-access-key

# ── Database (optional) ──
# Currently using JSON file storage by default.
# PostgreSQL is optional for session persistence:
# DATABASE_URL=postgresql://user:pass@localhost:5432/icross
