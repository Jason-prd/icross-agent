# =============================================================================
# iCross Agent — Frontend Docker Image (Vite Dev Server)
# =============================================================================
FROM node:18-slim

WORKDIR /app

# Install dependencies first (layer caching)
COPY package.json package-lock.json* ./
RUN npm install

# Copy source
COPY . .

EXPOSE 3000

CMD ["npx", "vite", "--port", "3000", "--strictPort", "--host"]
