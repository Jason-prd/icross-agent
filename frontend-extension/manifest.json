{
  "name": "icross-extension",
  "version": "0.1.0",
  "description": "iCross Agent browser extension — one-click product sourcing from 1688, 拼多多, 淘宝",
  "manifest_version": 3,
  "permissions": [
    "storage",
    "contextMenus",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://*.1688.com/*",
    "https://pinduoduo.com/*",
    "https://mobile.yangkeduo.com/*",
    "https://detail.tmall.com/*",
    "https://item.taobao.com/*",
    "http://localhost:8000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "iCross 选品助手",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://detail.1688.com/*"],
      "js": ["content-1688.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*.pinduoduo.com/*", "https://mobile.yangkeduo.com/*"],
      "js": ["content-pinduoduo.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://detail.tmall.com/*", "https://item.taobao.com/*"],
      "js": ["content-taobao.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
